# V6.0: transient build dirs produced by acceptance tests
# (they compile netlify/functions/_shared/*.mjs to .js via tsc so
# the tests can import them as ESM). Recreated on every test run.
scripts/.v6-build-*
# V5.7 acceptance test transient build dir (TS sources compiled
# to .js for the test's ESM imports). Recreated on every test run.
scripts/.v57-build
# Local run-all-acceptance helper (not a test, not a production
# script — only used to invoke every acceptance suite in one go
# during verification).
scripts/_run-all.mjs
# V6.0: gateway deployment staging. Recreated on every
# gateway-site build by scripts/copy-gateway-files.mjs. The
# staging directory is the gateway site's `functions` source;
# never edit files inside it directly — edit the source-of-truth
# files in netlify/functions/ instead.
netlify/gateway/functions-staging/
