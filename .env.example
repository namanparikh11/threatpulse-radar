# V6.2 — ThreatPulse Radar portable configuration.
#
# This file lists every environment variable the
# application reads. Copy to `.env` and adjust for your
# deployment. No secret values are included; see the
# documentation for the credential contract.
#
# IMPORTANT: do NOT commit a real `.env` file. Use the
# example file as a reference only.

# ---- Storage backend ----
# 'netlify' (default) | 'filesystem' | 'memory'
# 'netlify' is required for the Netlify production
# deployment. 'filesystem' is the recommended setting
# for Hostinger Business, a VPS, or local development.
# 'memory' is for ephemeral CI runs and tests.
THREATPULSE_STORAGE_BACKEND=netlify

# For the filesystem backend, the root directory that
# will hold every Blob-store namespace. Each namespace
# (tpr-dataset, tpr-vulnrichment, tpr-github-advisory,
# tpr-baseline, tpr-public-intelligence) becomes a
# subdirectory under this root.
#
# Example: /var/lib/threatpulse/state
# (Hostinger Business: ~/domains/<your-domain>/state)
THREATPULSE_DATA_ROOT=

# For the Netlify backend, the cross-site credentials
# (used by the public-site Background Function to
# read the gateway-local store). These are NOT
# secrets; they are site identifiers. The actual HMAC
# pepper is configured in the Netlify environment.
THREATPULSE_SITE_ID=
THREATPULSE_BLOBS_TOKEN=

# ---- HTTP server (V6.2 portable) ----
# Bind host and port for the portable Node HTTP server.
THREATPULSE_HTTP_HOST=127.0.0.1
THREATPULSE_HTTP_PORT=8787

# ---- Job mode (V6.2 CLI) ----
# Set THREATPULSE_DRY_RUN=1 to have the CLI jobs report
# what they would do without writing. Useful for cron
# testing on a fresh deployment.
# THREATPULSE_DRY_RUN=0
